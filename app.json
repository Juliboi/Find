{
  "expo": {
    "name": "Diem",
    "slug": "diem",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "dayflow",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/diem-logo.png",
    "splash": {
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cholify.dayflow",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cholify.dayflow",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DayFlow uses your location to suggest nearby gyms, grocery stores, cafés, and other places when you ask."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b76ccaa1-9136-4863-890a-e8dbc3e2bd75"
      }
    },
    "owner": "cholifyapp"
  }
}
